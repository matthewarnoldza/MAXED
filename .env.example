# MAXED — environment template. Copy to .env.local and fill in real values.
# In production, set these in Vercel → Project Settings → Environment Variables.

# Turso (libSQL) — create a DB with the Turso CLI or dashboard, then copy URL + token.
TURSO_DATABASE_URL=libsql://<your-db>.turso.io
TURSO_AUTH_TOKEN=<your-turso-auth-token>

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_TITLE=MAXED
